# ============================================================
# AI 助手环境变量配置
# ============================================================
# 必填：LLM 提供商的 API Key
AI_API_KEY=your_api_key_here

# LLM 服务 baseURL（OpenAI 兼容协议）
# 通义千问 DashScope（默认推荐，有免费额度）:
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 智谱 GLM:
# AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 对话模型名称
# 通义千问: qwen-plus / qwen-turbo / qwen-max
# 智谱 GLM: glm-4-flash / glm-4
AI_MODEL=qwen-plus

# Embedding 模型名称（用于 RAG 向量检索）
# 通义千问: text-embedding-v2
# 智谱 GLM: embedding-2
AI_EMBEDDING_MODEL=text-embedding-v2

# ============================================================
# 安全防护配置
# ============================================================
# 可选：允许调用 /api/chat 的来源域名（逗号分隔）
# 配置后只接受来自这些域名的请求，防止 API 被盗刷
# 留空则不校验来源（不推荐生产环境留空）
# 示例: https://example.com,http://localhost:3000
AI_ALLOWED_ORIGINS=https://your-domain.com
